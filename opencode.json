  "permission": {
    "canvas_*": "allow",
    "bash": {
      "*": "ask",
      "pnpm dev -- --host 127.0.0.1 --port *": "allow",
      "env NODE_ENV=development pnpm exec vite --host 127.0.0.1 --port *": "allow",
      "rtk pnpm dev*": "allow",
      "uv run openopps*": "allow"
    },
    "external_directory": {
      "~/.local/share/opencode/worktree/**": "allow"
    },
    "lsp": "allow"
  },
  "provider": {
    "openai": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 180000,
        "setCacheKey": true,
        "reasoningEffort": "xhigh",
        "websearch_cited": {
          "model": "gpt-5.5"
        }
      },
      "models": {
        "gpt-5.5": {
          "variants": {
            "none": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "none",
              "reasoningSummary": null
            },
            "low": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "low",
              "reasoningSummary": null
            },
            "medium": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "medium",
              "reasoningSummary": null
            },
            "high": {
              "include": [
                "reasoning.encrypted_content"
              ],
              "reasoningEffort": "high",
              "reasoningSummary": null,
              "textVerbosity": "low"
            },
            "xhigh": {
              "include": [
