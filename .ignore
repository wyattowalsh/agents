# OpenCode AI-access guardrails for opencode-ignore.
# Keep high-noise generated assets out of tool context.
.git/**
.mypy_cache/**
.pytest_cache/**
.ruff_cache/**
.ty/**
.venv/**
__pycache__/**
dist/**
build/**
skills/*.zip
docs/dist/**
docs/.astro/**
node_modules/**
docs/node_modules/**

# Local/generated harness artifacts.
.agent/**
.claude/commands/**
.claude/skills/**
.codex/**
.crush/**
.cursor/commands/**
.cursor/skills/**
.gemini/commands/**
.gemini/skills/**
.github/prompts/**
.github/skills/**
.opencode/commands/**
.opencode/skills/**
.opencode/opencode-tree/**
.mcphub/**
.ralph/**

# Secrets and machine-local credential material.
.env*
!.env.example
!.env.sample
!.env.template
!.env.test
*.pem
*.key
*.p12
*.pfx
*.crt
credentials.json
auth.json
secrets.toml
mcp/secrets/**
mcp/servers/**

# Test and coverage artifacts.
artifacts/**
htmlcov/**
.coverage
*.log
context-cache.log
