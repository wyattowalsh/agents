# Copy to .env.mcphub and replace every placeholder locally.
# Do not commit .env.mcphub.

NODE_ENV=production
PORT=46683
BASE_PATH=
INIT_TIMEOUT=300000
MCPHUB_SETTING_PATH=mcp/mcphub/mcp_settings.json
MCPHUB_BASE_URL=http://127.0.0.1:46683
MCPHUB_PUBLIC_URL=https://mcp.w4w.dev/mcp

# Optional public exposure for ChatGPT custom MCP apps/connectors.
# Requires a named Cloudflare Tunnel and local credentials outside this repo.
MCPHUB_TUNNEL_ENABLED=false
MCPHUB_TUNNEL_PROVIDER=cloudflare
MCPHUB_TUNNEL_PROTOCOL=http2
# Either set MCPHUB_TUNNEL_TOKEN from the Cloudflare dashboard connector command,
# or set MCPHUB_TUNNEL_NAME plus MCPHUB_TUNNEL_CREDENTIALS_FILE for local config.
MCPHUB_TUNNEL_TOKEN=
MCPHUB_TUNNEL_NAME=mcphub
MCPHUB_TUNNEL_HOSTNAME=mcp.w4w.dev
MCPHUB_TUNNEL_TARGET_URL=http://127.0.0.1:46683
MCPHUB_TUNNEL_CREDENTIALS_FILE=/Users/ww/.cloudflared/replace-with-tunnel-id.json

# Optional Zapier Central handoff. Keep the real catch-hook URL in .env.mcphub.
MCPHUB_ZAPIER_WEBHOOK_URL=

# Required for dashboard login and signed admin/API tokens.
ADMIN_PASSWORD=replace-with-local-admin-password
JWT_SECRET=replace-with-local-jwt-secret

# Required by local AI clients that connect to MCPHub /mcp endpoints.
MCPHUB_BEARER_TOKEN=replace-with-local-bearer-token

# Smart Routing stays off unless you opt into the postgres profile and embeddings.
SMART_ROUTING_ENABLED=false
SMART_ROUTING_PROGRESSIVE_DISCLOSURE=false
SMART_ROUTING_EMBEDDING_PROVIDER=
SMART_ROUTING_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MAX_TOKENS=

# Leave DB_URL unset for file-backed mode. Setting DB_URL enables MCPHub database mode.
# DB_URL=postgresql://mcphub:replace-with-local-db-password@127.0.0.1:5432/mcphub
POSTGRES_DB=mcphub
POSTGRES_USER=mcphub
POSTGRES_PASSWORD=replace-with-local-db-password

# Optional server-specific secrets consumed by mcp/mcphub/mcp_settings.json.
BRAVE_API_KEY=
CONTEXT7_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
CRASH_STRICT_MODE=
MAX_HISTORY_SIZE=
CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS=1
CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS=1
