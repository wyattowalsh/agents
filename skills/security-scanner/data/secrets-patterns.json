[
  {"name": "AWS Access Key", "regex": "AKIA[0-9A-Z]{16}", "severity": "CRITICAL", "false_positive_hints": ["Test keys start with AKIAIOSFODNN7EXAMPLE"]},
  {"name": "AWS Secret Key", "regex": "(?i)aws_secret_access_key\\s*[=:]\\s*['\"]?([A-Za-z0-9/+=]{40})", "severity": "CRITICAL", "false_positive_hints": ["wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY is AWS example"]},
  {"name": "GitHub Token", "regex": "ghp_[A-Za-z0-9]{36}", "severity": "CRITICAL", "false_positive_hints": ["Check if in test/example file"]},
  {"name": "GitHub OAuth", "regex": "gho_[A-Za-z0-9]{36}", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "GitHub App Token", "regex": "ghu_[A-Za-z0-9]{36}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "GitHub Refresh Token", "regex": "ghr_[A-Za-z0-9]{36}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "GitLab Token", "regex": "glpat-[A-Za-z0-9\\-]{20,}", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "Slack Bot Token", "regex": "xoxb-[0-9]{10,}-[0-9]{10,}-[A-Za-z0-9]{24}", "severity": "CRITICAL", "false_positive_hints": ["xoxb-not-a-real-token is commonly used in docs"]},
  {"name": "Slack Webhook", "regex": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+", "severity": "HIGH", "false_positive_hints": []},
  {"name": "Stripe Secret Key", "regex": "sk_live_[A-Za-z0-9]{24,}", "severity": "CRITICAL", "false_positive_hints": ["sk_test_ prefixed keys are test mode"]},
  {"name": "Stripe Publishable Key", "regex": "pk_live_[A-Za-z0-9]{24,}", "severity": "MEDIUM", "false_positive_hints": ["Publishable keys are meant to be public but should not be in server code"]},
  {"name": "Google API Key", "regex": "AIza[0-9A-Za-z\\\\-_]{35}", "severity": "HIGH", "false_positive_hints": ["Check if key is restricted to specific APIs/referrers"]},
  {"name": "Google OAuth Client ID", "regex": "[0-9]+-[a-z0-9]+\\.apps\\.googleusercontent\\.com", "severity": "MEDIUM", "false_positive_hints": ["Client IDs are semi-public but should not leak server secrets"]},
  {"name": "Heroku API Key", "regex": "(?i)heroku[_\\s]*api[_\\s]*key\\s*[=:]\\s*['\"]?([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})", "severity": "HIGH", "false_positive_hints": []},
  {"name": "JWT Token", "regex": "eyJ[A-Za-z0-9-_]+\\.eyJ[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+", "severity": "HIGH", "false_positive_hints": ["Common in documentation and test fixtures"]},
  {"name": "SSH Private Key", "regex": "-----BEGIN (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----", "severity": "CRITICAL", "false_positive_hints": ["Very rare false positive -- almost always real"]},
  {"name": "PGP Private Key", "regex": "-----BEGIN PGP PRIVATE KEY BLOCK-----", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "Generic Password", "regex": "(?i)(?:password|passwd|pwd)\\s*[=:]\\s*['\"][^'\"]{8,}['\"]", "severity": "HIGH", "false_positive_hints": ["Check if value contains placeholder like YOUR_ or changeme"]},
  {"name": "Generic Secret", "regex": "(?i)(?:secret|token|api_key|apikey|api-key)\\s*[=:]\\s*['\"][^'\"]{8,}['\"]", "severity": "HIGH", "false_positive_hints": ["Check for placeholder patterns"]},
  {"name": "Database URL", "regex": "(?i)(?:postgres|mysql|mongodb|redis)://[^\\s'\"]+:[^\\s'\"]+@", "severity": "CRITICAL", "false_positive_hints": ["localhost URLs in dev config are lower risk"]},
  {"name": "SendGrid API Key", "regex": "SG\\.[A-Za-z0-9\\-_]{22}\\.[A-Za-z0-9\\-_]{43}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "Twilio API Key", "regex": "SK[0-9a-fA-F]{32}", "severity": "HIGH", "false_positive_hints": ["May match other hex strings"]},
  {"name": "Mailgun API Key", "regex": "key-[0-9a-zA-Z]{32}", "severity": "HIGH", "false_positive_hints": ["Common format may match non-Mailgun keys"]},
  {"name": "npm Token", "regex": "npm_[A-Za-z0-9]{36}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "PyPI Token", "regex": "pypi-[A-Za-z0-9\\-_]{50,}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "Azure Storage Key", "regex": "(?i)DefaultEndpointsProtocol=https;AccountName=[^;]+;AccountKey=[A-Za-z0-9+/=]{88}", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "Discord Bot Token", "regex": "[MN][A-Za-z\\d]{23,}\\.[\\w-]{6}\\.[\\w-]{27}", "severity": "HIGH", "false_positive_hints": []},
  {"name": "Telegram Bot Token", "regex": "[0-9]{8,10}:[A-Za-z0-9_-]{35}", "severity": "HIGH", "false_positive_hints": ["Format may match non-Telegram strings"]},
  {"name": "OpenAI API Key", "regex": "sk-[A-Za-z0-9]{20}T3BlbkFJ[A-Za-z0-9]{20}", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "Anthropic API Key", "regex": "sk-ant-api[0-9]{2}-[A-Za-z0-9\\-_]{80,}", "severity": "CRITICAL", "false_positive_hints": []},
  {"name": "High Entropy String", "regex": "(?i)(?:key|secret|token|password|credential)\\s*[=:]\\s*['\"]([A-Za-z0-9+/=]{32,})['\"]", "severity": "MEDIUM", "false_positive_hints": ["Verify Shannon entropy > 3.5 to reduce false positives"]}
]
