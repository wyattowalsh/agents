{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-master/discovery/wave-manifest",
  "title": "WaveManifest",
  "type": "object",
  "required": ["session_id", "wave", "expected_count", "tasks"],
  "properties": {
    "session_id": { "type": "string" },
    "wave": { "type": "integer", "minimum": 0 },
    "expected_count": { "type": "integer", "minimum": 0 },
    "resolved_count": { "type": "integer", "minimum": 0 },
    "max_wall_sec": { "type": "integer", "minimum": 0 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "outputs"],
        "properties": {
          "id": { "type": "string" },
          "role": {
            "type": "string",
            "enum": [
              "repo-auditor",
              "registry-scout",
              "web-researcher",
              "mcp-scout",
              "harness-scout",
              "plugin-scout",
              "hook-scout",
              "policy-scout",
              "ideator"
            ]
          },
          "partition_primary": { "type": "string" },
          "inputs": { "type": "object" },
          "outputs": {
            "type": "object",
            "required": ["artifact"],
            "properties": {
              "artifact": { "type": "string" },
              "schema": { "type": "string" }
            }
          },
          "timeout_sec": { "type": "integer", "minimum": 1 },
          "retries": { "type": "integer", "minimum": 0 },
          "readonly": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}