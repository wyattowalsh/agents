{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-master/discovery/gap-report",
  "title": "GapReport",
  "type": "object",
  "required": ["version", "generated_at", "domains"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string" },
    "repo_skill_count": { "type": "integer", "minimum": 0 },
    "installed_skill_count": { "type": "integer", "minimum": 0 },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "coverage", "priority"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "coverage": {
            "type": "string",
            "enum": ["none", "low", "medium", "good", "full"]
          },
          "priority": { "type": "integer" },
          "existing_skills": { "type": "array", "items": { "type": "string" } },
          "gaps": { "type": "array", "items": { "type": "string" } },
          "scout_queries": { "type": "array", "items": { "type": "string" } },
          "classification": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "mcp": { "type": "object" },
    "plugins": { "type": "object" },
    "harness": { "type": "object" },
    "hooks": { "type": "object" },
    "dedup_exclusions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}