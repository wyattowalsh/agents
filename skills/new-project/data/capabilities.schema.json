{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"required": ["capabilities"],
	"properties": {
		"schema_version": { "type": "integer" },
		"capabilities": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"id",
					"category",
					"label",
					"description",
					"risk_level",
					"external_side_effects",
					"mutates_files",
					"runs_install",
					"validation"
				],
				"properties": {
					"id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
					"category": { "type": "string" },
					"label": { "type": "string" },
					"description": { "type": "string" },
					"default_for": { "type": "array", "items": { "type": "string" } },
					"requires": { "type": "array", "items": { "type": "string" } },
					"conflicts": { "type": "array", "items": { "type": "string" } },
					"implies": { "type": "array", "items": { "type": "string" } },
					"risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
					"external_side_effects": { "type": "boolean" },
					"mutates_files": { "type": "boolean" },
					"runs_install": { "type": "boolean" },
					"commands": { "type": "array", "items": { "type": "string" } },
					"artifacts": { "type": "array", "items": { "type": "string" } },
					"validation": { "type": "array", "items": { "type": "string" } },
					"handoff_skills": { "type": "array", "items": { "type": "string" } },
					"docs_sources": { "type": "array", "items": { "type": "string" } },
					"notes": { "type": "string" }
				},
				"additionalProperties": false
			}
		}
	},
	"additionalProperties": false
}
