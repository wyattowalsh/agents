{
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server"],
      "env": { "BRAVE_API_KEY": "${BRAVE_API_KEY}" },
      "timeout": 600000
    },
    "chrome-devtools": {
      "command": "bash",
      "args": [
        "${REPO_ROOT}/scripts/mcphub/chrome-devtools-browser-url.sh"
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1",
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
      },
      "timeout": 600000
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "${CONTEXT7_API_KEY}"],
      "env": { "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}" },
      "timeout": 600000
    },
    "deepwiki": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.deepwiki.com/mcp"],
      "timeout": 600000
    },
    "docling": {
      "command": "uvx",
      "args": ["--from", "docling-mcp", "docling-mcp-server", "--transport", "stdio"],
      "timeout": 600000
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "mcp-fetch-server"],
      "timeout": 600000
    },
    "fetcher": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp"],
      "timeout": 600000
    },
    "package-version": {
      "command": "/Users/ww/go/bin/mcp-package-version",
      "args": [],
      "timeout": 600000
    },
    "repomix": {
      "command": "npx",
      "args": ["-y", "repomix", "--mcp"],
      "timeout": 600000
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" },
      "timeout": 600000
    },
    "duckduckgo-search": {
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"],
      "timeout": 600000
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": { "EXA_API_KEY": "${EXA_API_KEY}" },
      "timeout": 600000
    },
    "ffmpeg": {
      "command": "uv",
      "args": [
        "--directory",
        "/Users/ww/dev/projects/agents/mcp/servers/ffmpeg-mcp",
        "run",
        "ffmpeg-mcp"
      ],
      "timeout": 600000
    },
    "g-search": {
      "command": "npx",
      "args": ["-y", "g-search-mcp"],
      "timeout": 600000
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"],
      "timeout": 600000
    }
  }
}
