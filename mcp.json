    "wikipedia": {
      "command": "npx",
      "args": [
        "-y",
        "--prefer-offline",
        "wikipedia-mcp"
      ],
      "timeout": 600000
    },
    "wayback": {
      "command": "npx",
      "args": [
        "-y",
        "--prefer-offline",
        "mcp-wayback-machine"
      ],
      "timeout": 600000
    }
