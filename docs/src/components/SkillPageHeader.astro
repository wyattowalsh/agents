---
import { Badge } from '@astrojs/starlight/components';

interface Props {
  name: string;
  description: string;
  installCommand: string;
  usage?: string;
  badges?: Array<{ text: string; variant?: 'note' | 'success' | 'caution' | 'tip' | 'default' }>;
}

const { name, description, installCommand, usage, badges = [] } = Astro.props;
---

<div class="skill-page-header">
  {badges.map((b) => (
    <Badge text={b.text} variant={b.variant ?? 'note'} />
  ))}

  <p class="skill-page__title">{name}</p>
  <blockquote>{description}</blockquote>

  <div class="quick-start">
    <h2>Quick Start</h2>
    <p><strong>Install:</strong></p>
    <pre class="agents-scrollbar"><code>{installCommand}</code></pre>
    {usage && (
      <>
        <p><strong>Use:</strong> <code>{usage}</code></p>
      </>
    )}
  </div>
</div>

<style>
  .skill-page__title {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0.5rem 0 0;
    line-height: 1.3;
  }
  .skill-page-header blockquote {
    margin: 0.75rem 0 1rem;
  }
  .skill-page-header .quick-start pre {
    margin: 0.5rem 0 0;
  }
</style>
