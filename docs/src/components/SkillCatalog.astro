---
type SkillRow = {
  name: string;
  description: string;
  sourceType: string;
  sourceRoot: string;
  displaySource?: string;
  sourceKind?: string;
  sourceUrl?: string;
  trustTier: string;
  status?: string;
  provenanceStatus?: string;
  reviewStatus?: string;
  targetAgents?: string[];
  installedAgents?: string[];
  installCommand?: string;
  installable?: boolean;
  localInventoryOnly?: boolean;
  knowledge?: {
    references?: string[];
    scripts?: string[];
    evals?: string[];
    wordCount?: number;
  };
};

interface Props {
  skills?: SkillRow[];
  src?: string;
}

const { skills = [], src } = Astro.props;
const trustTiers = Array.from(new Set(skills.map((skill) => skill.trustTier).filter(Boolean))).sort();
const statuses = Array.from(
  new Set(skills.map((skill) => skill.status || skill.provenanceStatus || '').filter(Boolean))
).sort();
const reviewStates = Array.from(
  new Set(skills.map((skill) => skill.reviewStatus || skill.provenanceStatus || '').filter(Boolean))
).sort();
const agentOptions = Array.from(
  new Set(
    skills
      .flatMap((skill) => [...(skill.targetAgents ?? []), ...(skill.installedAgents ?? [])])
      .filter(Boolean)
  )
).sort();
---

<section class="skill-catalog" data-skill-catalog data-skill-src={src}>
  <div class="skill-catalog__filters">
    <label>
      <span>Search</span>
      <input data-skill-search type="search" placeholder="Search skills, sources, references..." />
    </label>
    <label>
      <span>Source</span>
      <select data-skill-source>
        <option value="all">All sources</option>
        <option value="custom">Custom</option>
        <option value="installed">Installed</option>
        <option value="curated-external">Curated external</option>
      </select>
    </label>
    <label>
      <span>Trust</span>
      <select data-skill-trust>
        <option value="all">All trust tiers</option>
        {trustTiers.map((tier) => <option value={tier}>{tier}</option>)}
      </select>
    </label>
    <label>
      <span>Status</span>
      <select data-skill-status>
        <option value="all">All statuses</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>
      <span>Review</span>
      <select data-skill-review>
        <option value="all">All review states</option>
        {reviewStates.map((state) => <option value={state}>{state}</option>)}
      </select>
    </label>
    <label>
      <span>Agent</span>
      <select data-skill-agent>
        <option value="all">All agents</option>
        {agentOptions.map((agent) => <option value={agent}>{agent}</option>)}
      </select>
    </label>
    <label>
      <span>Install</span>
      <select data-skill-installable>
        <option value="all">All install states</option>
        <option value="installable">Installable</option>
        <option value="local-only">Local only</option>
        <option value="not-installable">Not installable</option>
      </select>
    </label>
  </div>

  <p class="skill-catalog__count">
    Showing <strong data-skill-visible>{skills.length}</strong> of <span data-skill-total>{skills.length}</span> indexed skills.
  </p>

  <div class="skill-catalog__grid" data-skill-grid>
    {
      skills.map((skill) => {
        const knowledge = skill.knowledge ?? {};
        const displaySource = skill.displaySource || skill.sourceRoot;
        const agents = [...(skill.targetAgents ?? []), ...(skill.installedAgents ?? [])];
        const installState = skill.localInventoryOnly ? 'local-only' : skill.installable || skill.installCommand ? 'installable' : 'not-installable';
        const haystack = [
          skill.name,
          skill.description,
          displaySource,
          skill.sourceKind ?? '',
          skill.trustTier,
          skill.status ?? '',
          skill.provenanceStatus ?? '',
          skill.reviewStatus ?? '',
          ...agents,
          ...(knowledge.references ?? []),
        ]
          .join(' ')
          .toLowerCase();
        return (
          <article
            class:list={['skill-catalog-card', `skill-catalog-card--${skill.sourceType}`]}
            data-skill-card
            data-source={skill.sourceType}
            data-trust={skill.trustTier}
            data-status={skill.status || skill.provenanceStatus || ''}
            data-review={skill.reviewStatus || skill.provenanceStatus || ''}
            data-agents={agents.join(' ')}
            data-installable={installState}
            data-haystack={haystack}
          >
            <div class="skill-catalog-card__badges">
              <span>{skill.sourceType}</span>
              <span>{skill.trustTier}</span>
              {skill.status && <span>{skill.status}</span>}
              {skill.reviewStatus && <span>{skill.reviewStatus}</span>}
              {skill.localInventoryOnly && <span>local only</span>}
            </div>
            <h3>{skill.name}</h3>
            <p>{skill.description}</p>
            <dl>
              <div>
                <dt>Source</dt>
                <dd>{displaySource}</dd>
              </div>
              <div>
                <dt>Knowledge</dt>
                <dd>
                  {knowledge.wordCount ?? 0} words · {knowledge.references?.length ?? 0} refs ·{' '}
                  {knowledge.scripts?.length ?? 0} scripts · {knowledge.evals?.length ?? 0} evals
                </dd>
              </div>
              {
                skill.installedAgents?.length ? (
                  <div>
                    <dt>Installed</dt>
                    <dd>{skill.installedAgents.join(', ')}</dd>
                  </div>
                ) : null
              }
              {
                skill.targetAgents?.length ? (
                  <div>
                    <dt>Targets</dt>
                    <dd>{skill.targetAgents.join(', ')}</dd>
                  </div>
                ) : null
              }
            </dl>
            <div class="skill-catalog-card__actions">
              {skill.sourceType === 'custom' && <a href={`/skills/${skill.name}/`}>Details</a>}
              {skill.sourceUrl && <a href={skill.sourceUrl}>Source</a>}
            </div>
            {
              skill.installCommand && (
                <pre class="agents-scrollbar"><code>{skill.installCommand}</code></pre>
              )
            }
          </article>
        );
      })
    }
  </div>
</section>

<script>
  document.querySelectorAll('[data-skill-catalog]').forEach((catalog) => {
    const search = catalog.querySelector<HTMLInputElement>('[data-skill-search]');
    const source = catalog.querySelector<HTMLSelectElement>('[data-skill-source]');
    const trust = catalog.querySelector<HTMLSelectElement>('[data-skill-trust]');
    const status = catalog.querySelector<HTMLSelectElement>('[data-skill-status]');
    const review = catalog.querySelector<HTMLSelectElement>('[data-skill-review]');
    const agent = catalog.querySelector<HTMLSelectElement>('[data-skill-agent]');
    const installable = catalog.querySelector<HTMLSelectElement>('[data-skill-installable]');
    const count = catalog.querySelector('[data-skill-visible]');
    const total = catalog.querySelector('[data-skill-total]');
    const grid = catalog.querySelector<HTMLElement>('[data-skill-grid]');
    const src = catalog.getAttribute('data-skill-src');

    const escapeHtml = (value: unknown) =>
      String(value ?? '').replace(/[&<>"']/g, (char) => {
        const escapes: Record<string, string> = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        };
        return escapes[char] ?? char;
      });

    const renderSkill = (skill: any) => {
      const knowledge = skill.knowledge ?? {};
      const references = Array.isArray(knowledge.references) ? knowledge.references : [];
      const scripts = Array.isArray(knowledge.scripts) ? knowledge.scripts : [];
      const evals = Array.isArray(knowledge.evals) ? knowledge.evals : [];
      const installedAgents = Array.isArray(skill.installedAgents) ? skill.installedAgents : [];
      const targetAgents = Array.isArray(skill.targetAgents) ? skill.targetAgents : [];
      const agents = Array.from(new Set([...targetAgents, ...installedAgents]));
      const displaySource = skill.displaySource || skill.sourceRoot || '';
      const installState = skill.localInventoryOnly
        ? 'local-only'
        : skill.installable || skill.installCommand
          ? 'installable'
          : 'not-installable';
      const haystack = [
        skill.name,
        skill.description,
        displaySource,
        skill.sourceKind ?? '',
        skill.trustTier,
        skill.status ?? '',
        skill.provenanceStatus ?? '',
        skill.reviewStatus ?? '',
        ...agents,
        ...references,
      ]
        .join(' ')
        .toLowerCase();
      const badges = [skill.sourceType, skill.trustTier, skill.status, skill.reviewStatus, skill.localInventoryOnly ? 'local only' : '']
        .filter(Boolean)
        .map((badge) => `<span>${escapeHtml(badge)}</span>`)
        .join('');
      const installed = installedAgents.length
        ? `<div><dt>Installed</dt><dd>${escapeHtml(installedAgents.join(', '))}</dd></div>`
        : '';
      const targets = targetAgents.length
        ? `<div><dt>Targets</dt><dd>${escapeHtml(targetAgents.join(', '))}</dd></div>`
        : '';
      const actions = [
        skill.sourceType === 'custom' ? `<a href="/skills/${encodeURIComponent(skill.name)}/">Details</a>` : '',
        skill.sourceUrl ? `<a href="${escapeHtml(skill.sourceUrl)}">Source</a>` : '',
      ].join('');
      const command = skill.installCommand
        ? `<pre class="agents-scrollbar"><code>${escapeHtml(skill.installCommand)}</code></pre>`
        : '';
      return `<article class="skill-catalog-card skill-catalog-card--${escapeHtml(skill.sourceType)}" data-skill-card data-source="${escapeHtml(skill.sourceType)}" data-trust="${escapeHtml(skill.trustTier)}" data-status="${escapeHtml(skill.status || skill.provenanceStatus || '')}" data-review="${escapeHtml(skill.reviewStatus || skill.provenanceStatus || '')}" data-agents="${escapeHtml(agents.join(' '))}" data-installable="${escapeHtml(installState)}" data-haystack="${escapeHtml(haystack)}">
        <div class="skill-catalog-card__badges">${badges}</div>
        <h3>${escapeHtml(skill.name)}</h3>
        <p>${escapeHtml(skill.description)}</p>
        <dl>
          <div><dt>Source</dt><dd>${escapeHtml(displaySource)}</dd></div>
          <div><dt>Knowledge</dt><dd>${Number(knowledge.wordCount ?? 0)} words · ${references.length} refs · ${scripts.length} scripts · ${evals.length} evals</dd></div>
          ${installed}
          ${targets}
        </dl>
        <div class="skill-catalog-card__actions">${actions}</div>
        ${command}
      </article>`;
    };

    const populateSelect = (select: HTMLSelectElement | null, values: string[], allLabel: string) => {
      if (!select) return;
      select.innerHTML = [`<option value="all">${escapeHtml(allLabel)}</option>`]
        .concat(values.map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`))
        .join('');
    };

    let cards = Array.from(catalog.querySelectorAll('[data-skill-card]'));

    const apply = () => {
      const query = search?.value?.trim().toLowerCase() ?? '';
      const sourceValue = source?.value ?? 'all';
      const trustValue = trust?.value ?? 'all';
      const statusValue = status?.value ?? 'all';
      const reviewValue = review?.value ?? 'all';
      const agentValue = agent?.value ?? 'all';
      const installableValue = installable?.value ?? 'all';
      let visible = 0;
      cards.forEach((card) => {
        const matchesQuery = !query || card.getAttribute('data-haystack')?.includes(query);
        const matchesSource = sourceValue === 'all' || card.getAttribute('data-source') === sourceValue;
        const matchesTrust = trustValue === 'all' || card.getAttribute('data-trust') === trustValue;
        const matchesStatus = statusValue === 'all' || card.getAttribute('data-status') === statusValue;
        const matchesReview = reviewValue === 'all' || card.getAttribute('data-review') === reviewValue;
        const matchesAgent = agentValue === 'all' || card.getAttribute('data-agents')?.split(' ').includes(agentValue);
        const matchesInstallable = installableValue === 'all' || card.getAttribute('data-installable') === installableValue;
        const show = Boolean(
          matchesQuery &&
            matchesSource &&
            matchesTrust &&
            matchesStatus &&
            matchesReview &&
            matchesAgent &&
            matchesInstallable
        );
        card.toggleAttribute('hidden', !show);
        if (show) visible += 1;
      });
      if (count) count.textContent = String(visible);
    };

    const hydrate = async () => {
      if (!src || !grid) return;
      const response = await fetch(src);
      const skills = await response.json();
      const rows = Array.isArray(skills) ? skills : [];
      const trustValues = Array.from(new Set(rows.map((skill) => String(skill.trustTier || '')).filter(Boolean))).sort();
      const statusValues = Array.from(
        new Set(rows.map((skill) => String(skill.status || skill.provenanceStatus || '')).filter(Boolean))
      ).sort();
      const reviewValues = Array.from(
        new Set(rows.map((skill) => String(skill.reviewStatus || skill.provenanceStatus || '')).filter(Boolean))
      ).sort();
      const agentValues = Array.from(
        new Set(
          rows
            .flatMap((skill) => [
              ...(Array.isArray(skill.targetAgents) ? skill.targetAgents : []),
              ...(Array.isArray(skill.installedAgents) ? skill.installedAgents : []),
            ])
            .map((value) => String(value || ''))
            .filter(Boolean)
        )
      ).sort();
      populateSelect(trust, trustValues, 'All trust tiers');
      populateSelect(status, statusValues, 'All statuses');
      populateSelect(review, reviewValues, 'All review states');
      populateSelect(agent, agentValues, 'All agents');
      grid.innerHTML = rows.map(renderSkill).join('');
      cards = Array.from(catalog.querySelectorAll('[data-skill-card]'));
      if (total) total.textContent = String(cards.length);
      apply();
    };

    search?.addEventListener('input', apply);
    source?.addEventListener('change', apply);
    trust?.addEventListener('change', apply);
    status?.addEventListener('change', apply);
    review?.addEventListener('change', apply);
    agent?.addEventListener('change', apply);
    installable?.addEventListener('change', apply);
    hydrate().catch(() => {
      if (grid) grid.innerHTML = '<p class="skill-catalog__count">Unable to load the generated skill index.</p>';
    });
  });
</script>
