---
import StarlightHead from '@astrojs/starlight/components/Head.astro';
import VtbotStarlight from 'astro-vtbot/components/starlight/Base.astro';
import { visualAssets } from '../../generated-site-data.mjs';

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const socialCard = visualAssets.find((asset) => asset.id === 'social-card')?.src ?? '/social-card.png';
const ogImageUrl = Astro.site ? new URL(socialCard, Astro.site).href : '';
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://us.i.posthog.com';
---
<VtbotStarlight>
  <StarlightHead><slot /></StarlightHead>
</VtbotStarlight>
<link rel="canonical" href={canonicalUrl.href} />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
{ogImageUrl && <meta property="twitter:image" content={ogImageUrl} />}
{ogImageUrl && <meta property="og:image:alt" content="Open Graph preview for the Agents documentation site" />}
{ogImageUrl && <meta property="twitter:image:alt" content="Open Graph preview for the Agents documentation site" />}
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Agents Docs" />
<meta property="og:url" content={canonicalUrl.href} />
<meta name="twitter:card" content="summary_large_image" />

{posthogKey && (
  <script is:inline define:vars={{ posthogHost, posthogKey }}>
    (() => {
      const overrideCookieName = 'agents_docs_admin_flags';

      function readOverrides() {
        try {
          const cookieValue = document.cookie
            .split('; ')
            .find((entry) => entry.startsWith(`${overrideCookieName}=`))
            ?.split('=')
            .slice(1)
            .join('=');

          return cookieValue ? JSON.parse(decodeURIComponent(cookieValue)) : {};
        } catch {
          return {};
        }
      }

      function getDistinctId() {
        const storageKey = 'agents-docs-anon-id';
        const existing = window.localStorage.getItem(storageKey);
        if (existing) return existing;

        const generated = `anon_${crypto.randomUUID()}`;
        window.localStorage.setItem(storageKey, generated);
        return generated;
      }

      function sendEvent(event, properties) {
        const body = JSON.stringify({
          api_key: posthogKey,
          distinct_id: getDistinctId(),
          event,
          properties: {
            ...properties,
            '$process_person_profile': false,
            path: window.location.pathname,
            source: 'agents-docs-browser',
          },
          timestamp: new Date().toISOString(),
        });

        const captureUrl = new URL('/i/v0/e/', posthogHost).toString();
        if (navigator.sendBeacon) {
          navigator.sendBeacon(captureUrl, new Blob([body], { type: 'application/json' }));
          return;
        }

        fetch(captureUrl, {
          body,
          headers: { 'content-type': 'application/json' },
          keepalive: true,
          method: 'POST',
        }).catch(() => undefined);
      }

      const overrides = readOverrides();
      if (overrides.telemetry_capture === false) return;

      sendEvent('docs_pageview', {
        canonical_url: document.querySelector('link[rel="canonical"]')?.getAttribute('href') ?? window.location.href,
        page_title: document.title,
      });

      document.addEventListener('click', (event) => {
        const target = event.target instanceof HTMLElement ? event.target.closest('[data-telemetry-event]') : null;
        if (!(target instanceof HTMLElement)) return;

        sendEvent(target.dataset.telemetryEvent || 'docs_interaction', {
          href: target.getAttribute('href') ?? '',
          label: target.dataset.telemetryLabel ?? target.textContent?.trim().slice(0, 120) ?? '',
        });
      });

      window.addEventListener('error', (event) => {
        sendEvent('docs_client_error', {
          file: event.filename?.split('/').slice(-1)[0] ?? '',
          line: event.lineno ?? 0,
          message: String(event.message ?? '').slice(0, 200),
        });
      });

      window.addEventListener('unhandledrejection', (event) => {
        const reason = event.reason instanceof Error ? event.reason.message : String(event.reason ?? 'Unknown rejection');
        sendEvent('docs_client_promise_rejection', {
          message: reason.slice(0, 200),
        });
      });
    })();
  </script>
)}
