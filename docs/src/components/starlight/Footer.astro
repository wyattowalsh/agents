---
import Default from '@astrojs/starlight/components/Footer.astro';

const { id, sidebar } = Astro.locals.starlightRoute;
const path = typeof id === 'string' ? id : '';

// Determine category
let category = '';
if (path.startsWith('skills/') && path !== 'skills') category = 'skills';
else if (path.startsWith('agents/') && path !== 'agents') category = 'agents';
else if (path.startsWith('mcp/') && path !== 'mcp') category = 'mcp';

// Find siblings in same category from sidebar
let prevPage: { href: string; label: string } | null = null;
let nextPage: { href: string; label: string } | null = null;

if (category && sidebar) {
  type FlatEntry = { href: string; label: string; isCurrent: boolean };
  const flatEntries: FlatEntry[] = [];
  const flatten = (items: typeof sidebar) => {
    for (const item of items) {
      if (item.type === 'link' && item.href) {
        flatEntries.push({ href: item.href, label: item.label, isCurrent: item.isCurrent });
      }
      if (item.type === 'group' && item.entries) {
        flatten(item.entries);
      }
    }
  };
  flatten(sidebar);

  const categoryEntries = flatEntries.filter(e => {
    const href = e.href.replace(/^\/|\/$/g, '');
    return href.startsWith(category + '/') && href !== category;
  });

  const currentIndex = categoryEntries.findIndex(e => e.isCurrent);
  if (currentIndex > 0) prevPage = categoryEntries[currentIndex - 1];
  if (currentIndex >= 0 && currentIndex < categoryEntries.length - 1) nextPage = categoryEntries[currentIndex + 1];
}

// Get skill name for install footer
const skillName = category === 'skills' && !path.startsWith('skills/installed') ? path.replace('skills/', '') : null;
const installCommand = skillName
  ? `npx skills add github:wyattowalsh/agents --skill ${skillName} -y -g --agent claude-code --agent codex --agent gemini-cli --agent antigravity --agent github-copilot --agent opencode`
  : '';
---

{category && (prevPage || nextPage) && (
  <nav class="category-nav" aria-label="In-category navigation">
    <div class="category-nav-inner">
      {prevPage && (
        <a
          href={prevPage.href}
          class="category-nav-link category-nav-prev"
          data-telemetry-event="docs_category_navigation_clicked"
          data-telemetry-label={prevPage.label}
        >
          <span class="category-nav-dir">&larr; Previous</span>
          <span class="category-nav-title">{prevPage.label}</span>
        </a>
      )}
      {nextPage && (
        <a
          href={nextPage.href}
          class="category-nav-link category-nav-next"
          data-telemetry-event="docs_category_navigation_clicked"
          data-telemetry-label={nextPage.label}
        >
          <span class="category-nav-dir">Next &rarr;</span>
          <span class="category-nav-title">{nextPage.label}</span>
        </a>
      )}
    </div>
  </nav>
)}

{skillName && (
  <div class="skill-install-footer">
    <code>{installCommand}</code>
    <button
      type="button"
      class="skill-install-copy"
      data-install-command={installCommand}
      data-telemetry-event="docs_install_command_copied"
      data-telemetry-label={skillName}
    >
      Copy
    </button>
  </div>
)}

<Default><slot /></Default>

<script is:inline>
  (() => {
    const buttons = document.querySelectorAll('.skill-install-copy');
    for (const button of buttons) {
      button.addEventListener('click', async () => {
        const command = button.getAttribute('data-install-command') ?? '';
        if (!command) return;

        try {
          await navigator.clipboard.writeText(command);
          button.textContent = 'Copied';
        } catch {
          button.textContent = 'Failed';
        }

        window.setTimeout(() => {
          button.textContent = 'Copy';
        }, 1500);
      });
    }
  })();
</script>

<style>
  .category-nav {
    border-top: 1px solid var(--sl-color-gray-5);
    padding: 1.5rem 0;
    margin-top: 2rem;
  }
  .category-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .category-nav-inner {
      grid-template-columns: 1fr;
    }
    .category-nav-next {
      grid-column: 1;
    }
  }
  .category-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .category-nav-link:hover {
    border-color: var(--primary);
    background: oklch(0.15 0.02 285 / 0.2);
  }
  .category-nav-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }
  .category-nav-prev { grid-column: 1; text-align: left; }
  .category-nav-next { grid-column: 2; text-align: right; }
  .category-nav-dir {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .category-nav-title {
    font-weight: 500;
    color: var(--sl-color-text-accent);
  }
  .skill-install-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    text-align: center;
    padding: 1rem;
    margin-top: 1rem;
    border-radius: 8px;
    background: oklch(0.13 0.02 285 / 0.15);
    border: 1px solid var(--sl-color-gray-5);
  }
  .skill-install-footer code {
    font-size: 0.85rem;
    color: var(--sl-color-text-accent);
    user-select: all;
  }
  .skill-install-copy {
    border: 1px solid var(--sl-color-gray-5);
    background: transparent;
    color: var(--sl-color-text-accent);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .skill-install-copy:hover {
    border-color: var(--primary);
    transform: translateY(-1px);
  }
  :global([data-theme='light']) .category-nav-link:hover {
    background: oklch(0.95 0.02 285 / 0.3);
  }
  :global([data-theme='light']) .category-nav-dir {
    color: var(--sl-color-gray-3);
  }
  :global([data-theme='light']) .skill-install-footer {
    background: oklch(0.97 0.01 285 / 0.15);
  }
</style>
