{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocsArtifactRegistry",
  "type": "object",
  "required": ["version", "source_registries", "artifacts", "docs_truth_rules"],
  "properties": {
    "version": {"const": 1},
    "source_registries": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "mode", "owner_change", "must_not_hand_edit", "validation"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "mode": {"enum": ["canonical", "generated", "merged", "symlink", "symlinked-entries"]},
          "owner_change": {"type": "string", "pattern": "^agents-c[0-9]{2}-.+"},
          "must_not_hand_edit": {"type": "boolean"},
          "validation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "docs_truth_rules": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
