{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillsCatalogIndex",
  "type": "object",
  "required": ["version", "generated_at", "entries"],
  "properties": {
    "version": {"const": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill_id", "source_kind", "name", "description", "body_path"],
        "properties": {
          "skill_id": {"type": "string", "minLength": 1},
          "source_kind": {"enum": ["custom", "external"]},
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "install_command": {"type": "string"},
          "install_source": {"type": "string"},
          "trust_tier": {"type": "string"},
          "curated_status": {"type": "string"},
          "target_agents": {
            "type": "array",
            "items": {"type": "string"}
          },
          "provenance_status": {"type": "string"},
          "source_path": {"type": "string"},
          "risk_notes": {"type": "string"},
          "promotion_policy": {"type": "string"},
          "provenance_evidence": {"type": "string"},
          "selector_mode": {"type": "string"},
          "notes": {"type": "string"},
          "body_path": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
