{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillsCatalogIndex",
  "type": "object",
  "required": ["customSkillIndex", "externalSkillIndex", "allSkillIndex"],
  "properties": {
    "customSkillIndex": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillRow" }
    },
    "externalSkillIndex": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillRow" }
    },
    "allSkillIndex": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillRow" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "skillRow": {
      "type": "object",
      "required": ["name", "description", "sourcePath", "sourceKind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string", "minLength": 1 },
        "sourceKind": {
          "enum": ["custom", "curated-external", "external"]
        },
        "sourceType": { "type": "string" },
        "sourceRoot": { "type": "string" },
        "displaySource": { "type": "string" },
        "sourcePath": { "type": "string", "minLength": 1 },
        "sourceUrl": { "type": "string" },
        "installCommand": { "type": "string" },
        "installSource": { "type": "string" },
        "useCommand": { "type": "string" },
        "installable": { "type": "boolean" },
        "localInventoryOnly": { "type": "boolean" },
        "trustTier": { "type": "string" },
        "trustBadge": { "type": "string" },
        "trustBadgeVariant": { "type": "string" },
        "provenanceStatus": { "type": "string" },
        "status": { "type": "string" },
        "reviewStatus": { "type": "string" },
        "targetAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "installedAgents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "riskNotes": { "type": "string" },
        "promotionPolicy": { "type": "string" },
        "provenanceEvidence": { "type": "string" },
        "selectorMode": { "type": "string" },
        "unresolvedReason": { "type": "string" },
        "license": { "type": "string" },
        "version": { "type": "string" },
        "author": { "type": "string" },
        "model": { "type": "string" },
        "argumentHint": { "type": "string" },
        "userInvocable": { "type": "boolean" },
        "knowledge": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}