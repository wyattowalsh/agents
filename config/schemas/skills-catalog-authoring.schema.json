{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillsCatalogAuthoring",
  "type": "object",
  "required": ["source_kind", "name", "description"],
  "properties": {
    "skill_id": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "source_kind": {"enum": ["custom", "curated-external", "external"]},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "install_command": {"type": "string"},
    "install_source": {"type": "string"},
    "license": {"type": "string"},
    "license_status": {"type": "string"},
    "author": {"type": "string"},
    "version": {"type": "string"},
    "trust_tier": {"type": "string", "minLength": 1},
    "curated_status": {"type": "string"},
    "status": {"type": "string"},
    "target_agents": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "provenance_status": {"type": "string"},
    "source_path": {"type": "string"},
    "risk_notes": {"type": "string"},
    "promotion_policy": {"type": "string"},
    "provenance_evidence": {"type": "string"},
    "audit_date": {"type": "string"},
    "audited_head": {"type": "string"},
    "pin_policy": {"type": "string"},
    "no_pin_rationale": {"type": "string"},
    "source_list_evidence": {"type": "string"},
    "executable_surface": {"type": "string"},
    "allowed_tools": {"type": "string"},
    "hook_surface": {"type": "string"},
    "script_surface": {"type": "string"},
    "credential_behavior": {"type": "string"},
    "network_access": {"type": "string"},
    "file_access": {"type": "string"},
    "live_action_risk": {"type": "string"},
    "risk_category": {"type": "string"},
    "dedupe_notes": {"type": "string"},
    "unsupported_target_agents": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "selector_mode": {"type": "string"},
    "unresolved_reason": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
