{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CursorAgents",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "readonly", "model"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "readonly": {
            "type": "boolean"
          },
          "model": {
            "const": "inherit"
          },
          "is_background": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
