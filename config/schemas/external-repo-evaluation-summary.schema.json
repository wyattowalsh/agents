{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExternalRepoEvaluationSummary",
  "type": "object",
  "required": ["version", "source_manifest", "source_count", "status", "promotion_boundary", "coverage_docs", "priority_waves", "repo_ids"],
  "properties": {
    "version": {"const": 1},
    "source_manifest": {"type": "string", "minLength": 1},
    "source_count": {"type": "integer", "minimum": 1},
    "status": {"const": "discovery-only"},
    "promotion_boundary": {"type": "string", "minLength": 1},
    "coverage_docs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "priority_waves": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string", "minLength": 1}}},
    "repo_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^EXT-[0-9]{3}$"}}
  },
  "additionalProperties": false
}
