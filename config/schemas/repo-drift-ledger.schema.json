{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RepoDriftLedger",
  "type": "object",
  "required": ["version", "source_refs", "records"],
  "properties": {
    "version": {"const": 1},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "expected_mode",
          "current_state",
          "drift_risk",
          "owner_change",
          "next_action",
          "validation_command"
        ],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "expected_mode": {"enum": ["canonical", "generated", "merged", "symlink", "symlinked-entries"]},
          "current_state": {
            "enum": ["tracked-clean", "tracked-dirty", "untracked", "generated-live", "external-live", "not-checked"]
          },
          "drift_risk": {"enum": ["low", "medium", "high"]},
          "owner_change": {"type": "string", "pattern": "^(agents-c[0-9]{2}-.+|agents-platform-overhaul)$"},
          "next_action": {"type": "string", "minLength": 1},
          "validation_command": {"type": "string", "minLength": 1},
          "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
